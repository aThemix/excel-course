{
  "parser": "babel-eslint",
  "env": {
    "es6": true,
    "browser": true,
    "node": true,
    "jest/globals": true
  },
  "rules": {
    "semi": "off",
	"arrow-parens": "off",
	"comma-dangle": "off",
    "require-jsdoc": "off",
    "no-trailing-spaces": "off",
    "quotes": ["error", "single", { "allowTemplateLiterals": true }],
    "indent": ["error", 4],
    "operator-linebreak": "off"
  },
  "plugins": ["jest"],
  "extends": ["eslint:recommended", "google"]
}
